{
  "DataAccess": {
    "Orm": "efcore"
  },
  "Database": {
    "Provider": "postgres"
  },
  "ConnectionStrings": {
    "PostgresConnection": "Host=localhost;Port=5432;Database=OlympusCoreMultitenantDb;Username=postgres;Password=postgres",
    "SqlServerConnection": "Server=localhost,1433;Database=OlympusCoreMultitenantDb;User Id=sa;Password=YourStrong@Passw0rd;TrustServerCertificate=True",
    "Redis": "localhost:6379"
  },
  "Auth": {
    "EmailUniquenessScope": "PerTenant"
  },
  "Caching": {
    "UseRedis": false,
    "RedisInstanceName": "olympus:",
    "PermissionsTtlMinutes": 30,
    "MenusTtlMinutes": 30,
    "RolesTtlMinutes": 30,
    "RolePermissionsTtlMinutes": 30
  },
  "Jwt": {
    "Issuer": "OlympusCoreMultitenant",
    "Audience": "OlympusCoreMultitenant.Client",
    "SecretKey": "CHANGE_THIS_TO_A_STRONG_SECRET_KEY_WITH_AT_LEAST_32_CHARACTERS",
    "ExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 7
  },
  "Smtp": {
    "Host": "smtp.mailserver.local",
    "Port": 587,
    "Username": "smtp-user",
    "Password": "smtp-password",
    "FromAddress": "no-reply@project.local",
    "FromName": "OlympusCoreMultitenant",
    "UseSsl": true
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "Properties": {
      "Application": "OlympusCoreMultitenant.Api"
    },
    "EnableSeq": true,
    "SeqServerUrl": "http://localhost:5341"
  },
  "AllowedHosts": "*"
}
